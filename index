</code></pre>
          </figure>
          <figure class="code-card">
            <figcaption class="code-caption"><span class="caption-badge">YAML</span></figcaption>
            <pre class="code-pre"><code class="language-yaml">InterventionStep:
  id: UUID
  plan_id: UUID
  step_order: integer              # 步骤顺序
  
  # 执行配置
  action_type: enum (
    send_email |                   # 发送邮件
    make_call |                    # 打电话
    send_push |                    # 推送通知
    create_ticket |                # 创建工单
    update_field |                 # 更新CRM字段
    escalate_to_human |            # 升级给人
    wait_and_reevaluate            # 等待并重新评估
  )
  
  # 超时
  timeout: duration                # 此步骤超时时间
  max_retries: integer             # 最大重试次数
  
  # 条件执行
  execute_condition: string        # "如果不满足下个步骤的条件，则不再推进"
  
  # 结果
  status: enum (pending | completed | skipped | failed)
  completed_at: datetime
  result_notes: text
</code></pre>
