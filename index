            <figcaption class="code-caption"><span class="caption-badge">YAML</span></figcaption>
            <pre class="code-pre"><code class="language-yaml">PipelineVersion:
  id: UUID
  pipeline_definition_id: UUID
  version_number: integer         # v1, v2, v3
  yaml_definition: text           # 完整的 YAML 定义
  change_description: text        # 变更说明
  deployed_at: datetime
  deployed_by: UUID
  
  # A/B 测试支持
  ab_testing_group: string        # "control" / "variant"
  ab_test_metric: string          # "conversion_rate" / "velocity"
  
  # 效果
