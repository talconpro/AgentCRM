          <h3 class="heading-level-3" id="52-pipeline-as-code-的语法设计">5.2 Pipeline as Code 的语法设计</h3>
          <figure class="code-card">
            <figcaption class="code-caption"><span class="caption-badge">YAML</span></figcaption>
            <pre class="code-pre"><code class="language-yaml"># 一个完整的标准销售管道定义

pipeline:
  name: "标准B2B销售管道"
  version: "1.2"
  description: "适用于客单价 10-50 万的 SaaS/B2B 标准跟进流程"

  stages:
    # 阶段 1：线索确认
    - name: "线索确认"
      id: lead_verification
      entry_conditions:
        - "pipeline.get_score(opportunity) &gt; 0.5"     # 线索评分大于0.5
        - "opportunity.source != 'internal'"           # 非内部线索
      exit_conditions:
        - "agent.email_analysis.reply_received == true"
        - "OR agent.call_analysis.contact_made == true"
        - "AND agent.sentiment_analysis.positive == true"
      actions:
        - agent: "L1_sales"
          template: "initial_outreach"
          timeout: "48h"
          max_followups: 3
        - if: "agent.reply_received == false AND 48h_passed"
          then:
            action: "call"
            priority: "high"
      human_intervention:
        condition: "opportunity.tcv &gt; 500000"          # 超50万需人确认是否跟进
        action: "人工审批线索分配"

    # 阶段 2：需求确认
    - name: "需求确认"
      id: qualification
      entry_conditions:
        - "stage_1.completed == true"
      exit_conditions:
        - "agent.qualification_doc.completed == true"
        - "agent.qualification_doc.budget_confirmed == true"
        - "agent.qualification_doc.timeline_confirmed == true"
        - "agent.qualification_doc.authority_confirmed == true"
      actions:
        - agent: "L2_sales"
          task: "conduct_discovery"
          deliverable: "qualification_doc"
        - agent: "demo_agent"
          task: "schedule_demo"
        - agent: "relationship_agent"
          task: "find_referrals"
      human_intervention:
        condition: "agent.qualification_doc.complexity == 'high'"
        action: "销售审核需求文档"

    # 阶段 3：方案与报价
    - name: "方案与报价"
      id: proposal
      entry_conditions:
        - "stage_2.completed == true"
      exit_conditions:
        - "quote.sent == true"
      actions:
        - agent: "L2_sales"
          task: "generate_proposal"
          input: "qualification_doc"
        - agent: "quote_agent"
          task: "generate_quote"
          input: "proposal"
        - agent: "quote_agent"
          task: "apply_discount"
          constraints:
            max_discount: "0.15"
            require_approval: "discount &gt; 0.10"
      human_intervention:
        condition: "quote.discount &gt; 0.10"
        action: "主管审批折扣"

    # 阶段 4：谈判与签约
    - name: "谈判与签约"
      id: negotiation
      entry_conditions:
        - "stage_3.completed == true"
      exit_conditions:
        - "contract.signed == true"
        - "OR opportunity.status == 'closed_lost'"
      actions:
        - agent: "L2_sales"
          task: "negotiation_support"
          provide: "competitive_intelligence"
        - agent: "legal_agent"
          task: "contract_review"
        - human: "主销售"
          task: "final_negotiation"
          note: "此阶段需要人主导，Agent 提供AI情报支持"
      human_intervention:
        condition: "true"      # 谈判阶段始终人工主导
        action: "销售主导，Agent 辅助"

  monitoring:
    health_checks:
      - name: "pipeline_velocity"
        metric: "机会在各阶段的平均停留时间"
        alert: "如果阶段停留时间超过设定的50%"
      - name: "pipeline_conversion"
        metric: "各阶段的转化率"
        alert: "如果转化率低于历史平均的50%"
      - name: "agent_performance"
        metric: "Agent 判断准确率"
        alert: "如果人推翻Agent判断的频率 &gt; 20%"

  learning:
    enabled: true
    feedback_loop: "每次人的干预都作为训练数据"
    auto_optimize: "邮件模板、跟进节奏、触发条件"
</code></pre>
          </figure>
