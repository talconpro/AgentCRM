  <style>
    :root {
      --bg: #f6f3ee;
      --paper: #fffdf8;
      --paper-2: #fbf7ef;
      --text: #24201b;
      --muted: #766b5f;
      --soft: #e9dfd2;
      --line: #ded1bf;
      --accent: #8a5a2b;
      --accent-2: #b7791f;
      --accent-3: #2f6f73;
      --code-bg: #1f2528;
      --code-text: #eef3ef;
      --shadow: 0 22px 70px rgba(61, 43, 28, .11);
      --radius: 22px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      background:
        radial-gradient(circle at 6% 0%, rgba(183, 121, 31, .10), transparent 28rem),
        radial-gradient(circle at 90% 12%, rgba(47, 111, 115, .10), transparent 26rem),
        var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Sans CJK SC", sans-serif;
      line-height: 1.82;
      letter-spacing: .01em;
    }

    a {
      color: inherit;
    }

    .layout {
      display: grid;
      grid-template-columns: 300px minmax(0, 1fr);
      min-height: 100vh;
    }

    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow: auto;
      padding: 28px 22px;
      border-right: 1px solid rgba(138, 90, 43, .16);
      background: rgba(255, 253, 248, .74);
      backdrop-filter: blur(18px);
    }

    .brand {
      padding: 8px 8px 22px;
      border-bottom: 1px solid var(--soft);
      margin-bottom: 18px;
    }

    .brand-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--accent);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .brand-kicker::before {
      content: "";
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--accent), var(--accent-3));
    }

    .brand-title {
      margin: 12px 0 8px;
      font-size: 20px;
      line-height: 1.35;
      font-weight: 800;
    }

    .brand-subtitle {
      margin: 0;
      color: var(--muted);
      font-size: 13px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin: 18px 0 20px;
    }

    .stat {
      padding: 12px;
      border: 1px solid var(--soft);
      border-radius: 16px;
      background: rgba(255, 255, 255, .52);
    }

    .stat b {
      display: block;
      font-size: 18px;
      line-height: 1;
      color: var(--accent);
    }

    .stat span {
      display: block;
      margin-top: 6px;
      font-size: 12px;
      color: var(--muted);
    }

    .toc-label {
      margin: 18px 8px 10px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .toc {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .toc a {
      display: block;
      padding: 8px 10px;
      border-radius: 12px;
      color: #5d5248;
      text-decoration: none;
      font-size: 13px;
      line-height: 1.35;
    }

    .toc a:hover {
      background: rgba(138, 90, 43, .10);
      color: var(--accent);
    }

    .toc .toc-title-link {
      color: var(--accent);
      font-weight: 800;
      background: rgba(138, 90, 43, .08);
    }

    .main {
      min-width: 0;
      padding: 42px clamp(22px, 5vw, 78px) 90px;
    }

    .reader-shell {
      max-width: 1060px;
      margin: 0 auto;
    }

    .cover {
      position: relative;
      overflow: hidden;
      padding: clamp(34px, 6vw, 76px);
      border: 1px solid rgba(138, 90, 43, .18);
      border-radius: 34px;
      background:
        linear-gradient(135deg, rgba(255, 253, 248, .98), rgba(251, 247, 239, .92)),
        radial-gradient(circle at top right, rgba(47, 111, 115, .12), transparent 20rem);
      box-shadow: var(--shadow);
      margin-bottom: 36px;
    }

    .cover::after {
      content: "CRM 4.0";
      position: absolute;
      right: -20px;
      bottom: -52px;
      font-size: clamp(80px, 13vw, 180px);
      font-weight: 900;
      line-height: 1;
      color: rgba(138, 90, 43, .07);
      letter-spacing: -.08em;
    }

    .cover-kicker {
      position: relative;
      z-index: 1;
      display: inline-flex;
      padding: 6px 12px;
      border: 1px solid rgba(138, 90, 43, .22);
      border-radius: 999px;
      color: var(--accent);
      font-size: 13px;
      font-weight: 800;
      background: rgba(255, 255, 255, .5);
    }

    .cover h1 {
      position: relative;
      z-index: 1;
      /* max-width: 780px; */
      margin: 22px 0 16px;
      font-size: clamp(34px, 5.6vw, 70px);
      line-height: 1.08;
      letter-spacing: -.045em;
    }

    .cover-desc {
      position: relative;
      z-index: 1;
      max-width: 760px;
      margin: 0;
      color: var(--muted);
      font-size: 17px;
    }

    .content {
      padding: clamp(28px, 5vw, 70px);
      border-radius: 34px;
      background: rgba(255, 253, 248, .94);
      border: 1px solid rgba(138, 90, 43, .16);
      box-shadow: var(--shadow);
    }

    .content>*:first-child {
      margin-top: 0;
    }

    .content h1,
    .content h2,
    .content h3,
    .content h4 {
      color: #221c15;
      scroll-margin-top: 28px;
    }

    .content h1.book-main-title {
      display: none;
    }

    .content h1.chapter-title {
      margin: 88px 0 26px;
      padding: 30px 0 18px;
      border-top: 1px solid var(--soft);
      font-size: clamp(30px, 4vw, 48px);
      line-height: 1.16;
      letter-spacing: -.03em;
    }

    .content h1.chapter-title::before {
      content: "Chapter";
      display: block;
      width: max-content;
      margin-bottom: 12px;
      padding: 3px 10px;
      border-radius: 999px;
      background: rgba(138, 90, 43, .10);
      color: var(--accent);
      font-size: 12px;
      letter-spacing: .12em;
      text-transform: uppercase;
    }

    .content h2 {
      margin: 48px 0 18px;
      padding-left: 16px;
      border-left: 5px solid var(--accent-2);
      font-size: 26px;
      line-height: 1.3;
    }

    .content h3 {
      margin: 34px 0 14px;
      font-size: 21px;
    }

    .content h4 {
      margin: 26px 0 10px;
      font-size: 18px;
      color: var(--accent);
    }

    .content p {
      margin: 14px 0;
    }

    .content p,
    .content li {
      font-size: 16.5px;
    }

    .content strong {
      color: #111;
      font-weight: 800;
    }

    .content ul,
    .content ol {
      padding-left: 1.4em;
    }

    .content li+li {
      margin-top: 6px;
    }

    .content blockquote {
      margin: 28px 0;
      padding: 20px 24px;
      border-left: 5px solid var(--accent-3);
      border-radius: 0 18px 18px 0;
      background: rgba(47, 111, 115, .08);
      color: #344547;
    }

    .meta-line {
      margin: 8px 0 !important;
      padding: 10px 14px;
      border: 1px solid rgba(138, 90, 43, .14);
      border-radius: 14px;
      background: linear-gradient(180deg, rgba(255, 255, 255, .70), rgba(251, 247, 239, .60));
      color: #4c4036;
    }

    .section-break {
      border: 0;
      height: 1px;
      margin: 34px 0;
      background: linear-gradient(90deg, transparent, var(--line), transparent);
    }

    .table-card,
    .diagram-card,
    .code-card {
      margin: 28px 0 32px;
      border-radius: 22px;
      overflow: hidden;
      border: 1px solid rgba(138, 90, 43, .16);
      background: #fff;
      box-shadow: 0 14px 40px rgba(61, 43, 28, .08);
    }

    .table-caption,
    .diagram-caption,
    .code-caption {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 16px;
      border-bottom: 1px solid rgba(138, 90, 43, .14);
      background: linear-gradient(90deg, rgba(138, 90, 43, .09), rgba(47, 111, 115, .07));
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
    }

    .caption-badge {
      display: inline-flex;
      align-items: center;
      padding: 3px 9px;
      border-radius: 999px;
      background: rgba(138, 90, 43, .12);
      color: var(--accent);
      font-weight: 900;
      letter-spacing: .04em;
    }

    .caption-hint {
      color: #9a8d80;
      font-weight: 600;
    }

    .table-scroll {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .data-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      min-width: 620px;
      font-size: 14.5px;
    }

    .data-table th {
      position: sticky;
      top: 0;
      background: #f3eadf;
      color: #3b2f24;
      font-weight: 900;
      text-align: left;
      white-space: nowrap;
    }

    .data-table th,
    .data-table td {
      padding: 12px 14px;
      border-bottom: 1px solid #eadfd1;
      vertical-align: top;
    }

    .data-table tbody tr:nth-child(even) td {
      background: #fffaf2;
    }

    .data-table tbody tr:hover td {
      background: #f7efe5;
    }

    .data-table .first-col {
      font-weight: 700;
      color: #3d3026;
    }

    .diagram-card {
      background: linear-gradient(145deg, #fbf6ee, #eef5f4);
    }

    .diagram-pre {
      margin: 0;
      padding: clamp(18px, 3vw, 30px);
      overflow-x: auto;
      color: #243334;
      background:
        linear-gradient(rgba(255, 255, 255, .64), rgba(255, 255, 255, .64)),
        repeating-linear-gradient(0deg, transparent, transparent 23px, rgba(47, 111, 115, .045) 24px);
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
      font-size: 14px;
      line-height: 1.55;
    }

    .diagram-pre code {
      font-family: inherit;
    }

    .code-card {
      background: var(--code-bg);
      border-color: rgba(31, 37, 40, .7);
    }

    .code-caption {
      background: #171c1f;
      color: #b8c4c0;
      border-color: rgba(255, 255, 255, .09);
      justify-content: flex-start;
    }

    .code-caption .caption-badge {
      background: rgba(255, 255, 255, .10);
      color: #e7d3ad;
    }

    .code-pre {
      margin: 0;
      padding: 20px 22px;
      overflow-x: auto;
      background: var(--code-bg);
      color: var(--code-text);
      font-family: "SFMono-Regular", Consolas, "Liberation Mono", Menlo, monospace;
      font-size: 13.5px;
      line-height: 1.62;
    }

    .code-pre code {
      font-family: inherit;
    }

    .backtop {
      position: fixed;
      right: 22px;
      bottom: 22px;
      width: 44px;
      height: 44px;
      border-radius: 999px;
      display: grid;
      place-items: center;
      border: 1px solid rgba(138, 90, 43, .2);
      background: rgba(255, 253, 248, .86);
      box-shadow: 0 12px 30px rgba(61, 43, 28, .12);
      text-decoration: none;
      color: var(--accent);
      font-weight: 900;
    }

    @media (max-width: 980px) {
      .layout {
        display: block;
      }

      .sidebar {
        position: relative;
        height: auto;
        border-right: 0;
        border-bottom: 1px solid var(--soft);
      }

      .toc {
        max-height: 280px;
        overflow: auto;
      }

      .main {
        padding: 24px 14px 70px;
      }

      .content {
        padding: 24px 18px;
        border-radius: 24px;
      }

      .cover {
        border-radius: 24px;
        padding: 30px 22px;
      }
    }

    @media print {
      body {
        background: #fff;
      }

      .layout {
        display: block;
      }

      .sidebar,
      .backtop {
        display: none;
      }

      .main {
        padding: 0;
      }

      .reader-shell {
        max-width: none;
      }

      .cover,
      .content {
        box-shadow: none;
        border: 0;
        border-radius: 0;
      }

      .content h1.chapter-title {
        break-before: page;
      }

      .table-card,
      .diagram-card,
      .code-card {
        break-inside: avoid;
        box-shadow: none;
      }
    }

    .toc a.active {
      background: rgba(47, 111, 115, .11);
      color: var(--accent-3);
      font-weight: 800;
    }
  </style>
</head>

