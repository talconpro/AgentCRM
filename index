              <table class="data-table">
                <thead>
                  <tr>
                    <th class="first-col">需求</th>
                    <th>传统 CRM 的"解决方案"</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="first-col">谁是决策者</td>
                    <td>在 Contact 上加一个"决策角色"下拉框</td>
                  </tr>
                  <tr>
                    <td class="first-col">谁和谁是同事</td>
                    <td>看他们的 AccountId 是否相同（隐式）</td>
                  </tr>
                  <tr>
                    <td class="first-col">谁是供应商联系人</td>
                    <td>在 Account 的"类型"字段注明"供应商"</td>
                  </tr>
