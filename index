                  </tr>
                </tbody>
              </table>
            </div>
          </figure>
          <h3 class="heading-level-3" id="42-healthscore-对象模型">4.2 HealthScore 对象模型</h3>
          <figure class="code-card">
            <figcaption class="code-caption"><span class="caption-badge">YAML</span></figcaption>
            <pre class="code-pre"><code class="language-yaml">HealthScore:
  id: UUID
  customer_id: UUID
  account_id: UUID
  
  # ===== 综合评分 =====
  overall_score: float (0-100)       # 综合健康度
  overall_trend: enum (
    rapidly_improving |              # 快速改善（+15/月以上）
    improving |                       # 改善
    stable |                          # 稳定
    declining |                       # 下降
    rapidly_declining                # 快速下降（-15/月以上）
  )
  
  # ===== 4 个子维度 =====
  usage_health:
    score: float (0-100)
    trend: enum
    components:
      login_frequency: float         # 登录频次（与历史对比）
      feature_adoption: float        # 功能采用率
      session_depth: float           # 会话深度
      api_calls: float               # API调用量（如有）
    last_peak: datetime              # 最近一次使用高峰
    last_dip: datetime               # 最近一次使用低谷
  
  communication_health:
    score: float (0-100)
    trend: enum
    components:
      sentiment_trend: float         # 情感趋势（-1到1）
      response_time: float           # 响应时间（平均，小时）
      contact_frequency: float       # 接触频次（与最佳频次对比）
      satisfaction_score: float      # CSAT/NPS
    last_full_survey: datetime      # 最近一次NPS/CSAT调研
  
  relationship_health:
    score: float (0-100)
    trend: enum
    components:
      champion_stability: float      # 支持者稳定性（关键人是否变化）
      relationship_strength: float   # 关系强度（图谱中的平均边强度）
      sponsor_count: integer         # 支持者数量
      decision_maker_engagement: float # 决策者参与度
    last_relationship_change: datetime # 最近一次关系变化
  
  financial_health:
    score: float (0-100)
    trend: enum
    components:
      payment_history: float         # 付款记录（0=逾期, 1=准时）
      renewal_probability: float     # 续费概率（AI预测）
      expansion_potential: float     # 扩展潜力（向上销售的预估）
      upsell_velocity: float         # 扩展速度（年增长率）
    last_payment_date: datetime
  
  # ===== 根因分析 =====
  root_causes: [RootCause]           # 当前分数的根因列表
  
  # ===== 预测 =====
  prediction:
    churn_probability_30d: float     # 30天内流失概率
    churn_probability_60d: float     # 60天内流失概率
    churn_probability_90d: float     # 90天内流失概率
    predicted_score_30d: float       # 30天后预测评分
    predicted_factors: [string]      # 驱动预测的关键因素
  
  # ===== 干预建议 =====
  suggested_interventions: [Intervention]
  
  # ===== 元数据 =====
  calculated_at: datetime
  score_version: string              # 评分模型版本
  confidence: float                   # 评分的置信度（0-1）
</code></pre>
          </figure>
          <h3 class="heading-level-3" id="43-rootcause-对象——为什么是这个分数">4.3 RootCause 对象——为什么是"这个分数"</h3>
          <figure class="code-card">
            <figcaption class="code-caption"><span class="caption-badge">YAML</span></figcaption>
            <pre class="code-pre"><code class="language-yaml">RootCause:
  id: UUID
  health_score_id: UUID
  customer_id: UUID
  
  # 根因信息
