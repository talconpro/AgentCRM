    signal_name: string  # 意图信号名称
    signal_threshold: float
</code></pre>
          </figure>
          <h3 class="heading-level-3" id="42-四种干预类型">4.2 四种干预类型</h3>
          <p>AI CS Agent 不是只发"关怀邮件"——它有四种完全不同的干预策略：</p>
          <p><strong>类型一：教育型干预</strong></p>
          <p>目标：提升客户的"使用能力"。使用能力低→使用频率低→流失风险高。教育型干预解决"客户不会用"的问题。</p>
          <figure class="code-card">
            <figcaption class="code-caption"><span class="caption-badge">YAML</span></figcaption>
            <pre class="code-pre"><code class="language-yaml">EducationIntervention:
  trigger: "usage_health.score &lt; 50 AND feature_adoption &lt; 30%"
  actions:
    - agent: "email_agent"
      task: "send_tutorial"
      content: "基于客户未使用的核心功能生成定制教程"
    - agent: "email_agent"
      task: "send_use_case"
      content: "展示同行业客户如何用该功能产生价值"
    - if: "7天无改善"
      then:
        agent: "outbound_agent"
        task: "schedule_1on1_training"
  expected_effect: "使用健康度提升15分以上"
  success_rate: 78%     # 历史数据
</code></pre>
          </figure>
          <p><strong>类型二：产品型干预</strong></p>
          <p>目标：解决客户的产品体验问题。健康度下降往往与产品问题直接相关——bug、性能、缺失的功能。产品型干预不是让 CSM 去修 bug——是让 Agent 自动分析问题类型，决定是"推送知识库"还是"创建工单"。
          </p>
          <figure class="code-card">
            <figcaption class="code-caption"><span class="caption-badge">YAML</span></figcaption>
            <pre class="code-pre"><code class="language-yaml">ProductIntervention:
  trigger: "ticket_volume &gt; 历史均值 * 2 AND tickets集中在同一功能"
  actions:
    - agent: "analysis_agent"
      task: "analyze_ticket_pattern"
      input: "近期工单内容"
    - if: "问题可以自助解决"
      then:
        agent: "email_agent"
        task: "send_solution_guide"
        content: "基于工单内容生成的定制解决指南"
    - if: "问题需要产品团队修复"
      then:
        agent: "ticket_agent"
        task: "create_product_bug"
        escalate_to: "engineering"
</code></pre>
          </figure>
          <p><strong>类型三：关怀型干预</strong></p>
          <p>目标：维护情感连接。客户使用体验好的情况下，流失风险很低——但偶尔也需要"情感加油"。关怀型干预不是为了解决问题，而是为了让客户感受到"被重视"。</p>
          <figure class="code-card">
            <figcaption class="code-caption"><span class="caption-badge">YAML</span></figcaption>
            <pre class="code-pre"><code class="language-yaml">CareIntervention:
  trigger: "客户进入续费窗口期 OR 合作周年 OR CSAT高分"
  actions:
    - agent: "email_agent"
      task: "send_personalized_thankyou"
      content: "基于客户使用数据生成个性化感谢信"
    - agent: "email_agent"
      task: "send_anniversary_message"
      content: "合作周年纪念 + 这一年使用成就回顾"
  expected_effect: "情感评分提升"
  success_rate: 95%
</code></pre>
          </figure>
          <p><strong>类型四：关系型干预</strong></p>
          <p>目标：修复或强化客户的关系网络。当关系健康度下降时，需要用"人"的干预——不是因为机器做不到，而是因为"来自高层的问候"本身就有价值。</p>
          <figure class="code-card">
            <figcaption class="code-caption"><span class="caption-badge">YAML</span></figcaption>
            <pre class="code-pre"><code class="language-yaml">RelationshipIntervention:
  trigger: "relationship_health.score &lt; 50"
  actions:
    - if: "champion_stability &lt; 0.3"  # 支持者不稳定
      then:
        agent: "relationship_agent"
        task: "identify_new_sponsor"
        input: "关系图谱+沟通记录"
    - if: "new_sponsor_found"
      then:
        agent: "email_agent"
        task: "send_introduction"
        content: "为新的决策者定制初接触邮件"
    - if: "关系修复复杂"
      then:
        escalate_to: "CSM"
        context: "Agent's analysis report"
</code></pre>
          </figure>
          <h3 class="heading-level-3" id="43-interventionplan-对象——完整的干预计划">4.3 InterventionPlan 对象——完整的干预计划</h3>
          <figure class="code-card">
            <figcaption class="code-caption"><span class="caption-badge">YAML</span></figcaption>
            <pre class="code-pre"><code class="language-yaml">InterventionPlan:
  id: UUID
  customer_id: UUID
  health_score_id: UUID
  
  # 计划概况
